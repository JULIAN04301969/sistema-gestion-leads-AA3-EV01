<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

  <!-- Nombre de la aplicación -->
  <display-name>Sistema Integral de Gestión de Leads</display-name>

  <!-- Página de bienvenida al ingresar a la aplicación -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- Servlet para gestión de Leads -->
  <servlet>
    <servlet-name>LeadServlet</servlet-name>
    <servlet-class>com.gestionleads.servlet.LeadServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LeadServlet</servlet-name>
    <url-pattern>/leads</url-pattern>
  </servlet-mapping>

  <!-- Servlet para gestión de Usuarios -->
  <servlet>
    <servlet-name>UsuarioServlet</servlet-name>
    <servlet-class>com.gestionleads.servlet.UsuarioServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>UsuarioServlet</servlet-name>
    <url-pattern>/usuarios</url-pattern>
  </servlet-mapping>

  <!-- Servlet para gestión de Seguimientos -->
  <servlet>
    <servlet-name>SeguimientoServlet</servlet-name>
    <servlet-class>com.gestionleads.servlet.SeguimientoServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>SeguimientoServlet</servlet-name>
    <url-pattern>/seguimientos</url-pattern>
  </servlet-mapping>

</web-app>